{
  "name": "imagegen-mcp",
  "version": "0.1.0",
  "description": "Provider-agnostic MCP server for image generation (OpenAI, Stability, Replicate, OpenAI-compatible). Tools: generate_image, edit_image, list_image_models, crop_image.",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "bin": {
    "imagegen-mcp": "src/server.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "sharp": "^0.34.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "license": "MIT"
}
